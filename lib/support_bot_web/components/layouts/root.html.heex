<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title suffix=" · Dylan Glover">
      {assigns[:page_title] || "Dylan Glover"}
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/app.js"}>
    </script>
    <script>
      // Apply the saved nav-collapsed state before first paint to avoid a flash.
      try {
        if (localStorage.getItem("dg-nav-collapsed") === "1") {
          document.documentElement.classList.add("nav-collapsed")
        }
      } catch (e) {}
    </script>
  </head>
  <body>
    {@inner_content}
    {live_render(@conn, SupportBotWeb.WidgetLive,
      id: "dylanbot-widget-live",
      session: %{"path" => @conn.request_path},
      sticky: true
    )}
  </body>
</html>
