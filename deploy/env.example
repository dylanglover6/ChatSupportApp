# Copy to /opt/support_bot/.env on the VM (chmod 600, owned by the support_bot user).
# Never commit the real values.

SECRET_KEY_BASE=
DATABASE_URL=ecto://support_bot:CHANGE_ME@localhost/support_bot_prod
PHX_HOST=dylanglover.com
PORT=4000
POOL_SIZE=10

# DylanBot's brain (see DEPLOY.md §7-8).
#   anthropic  — hosted Claude (production); requires ANTHROPIC_API_KEY below
#   ollama     — local model (dev default); no key needed
#   fallback   — deterministic, KB-grounded, no live model
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
# Optional override; defaults to claude-haiku-4-5 (cheapest hosted option).
# ANTHROPIC_MODEL=claude-haiku-4-5
