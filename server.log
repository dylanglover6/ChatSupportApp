INSERT INTO "messages" ("sources","role","content","conversation_id","inserted_at","updated_at") VALUES ($1,$2,$3,$4,$5,$6) RETURNING "id" [[%{"path" => "_build/dev/lib/support_bot/priv/kb/01_sso_saml_troubleshooting.md", "slug" => "sso-saml-troubleshooting", "snippet" => "FlowDesk workspaces can use SSO with a SAML identity provider such as Okta, Azure AD, or OneLogin. Most failed SAML sign-ins are caused by a mismatch between the identity provider configuration and the FlowDesk workspace SSO settings. The most common issue is an audience or entity ID mismatch after a workspace admin co", "title" => "SSO SAML Troubleshooting"}, %{"path" => "_build/dev/lib/support_bot/priv/kb/02_api_authentication.md", "slug" => "api-authentication", "snippet" => "FlowDesk API requests use bearer tokens created inside workspace settings. A token can stop working if it is revoked, rotated, copied with whitespace, scoped incorrectly, or sent to the wrong environment. API authentication problems usually appear as HTTP 401 Unauthorized responses.", "title" => "API Authentication"}, %{"path" => "_build/dev/lib/support_bot/priv/kb/03_webhook_delivery.md", "slug" => "webhook-delivery", "snippet" => "Thanks for the report. Webhook delays often happen when the endpoint times out or returns a non-2xx response. Please confirm the endpoint response code, timestamp, webhook ID, and signature verification result so we can review delivery logs.", "title" => "Webhook Delivery"}], "assistant", "This sounds like it may relate to SSO SAML Troubleshooting.\n\nA good next step is to share the exact error message, when it happened, and the affected workspace or user. If you want, I can also turn this into a support ticket.\n", 12, ~U[2026-06-16 19:25:21Z], ~U[2026-06-16 19:25:21Z]]
